# DGMTS Flask API (VPS) — DB + storage for the static site (optional; defaults in dbClient.js)
VITE_DGMTS_API_URL=https://imsite.dullesgeotechnical.com
#
# About page team grid: add Postgres table `about_employees` (columns: id, name, department, image_url, sort_order, is_active)
# and storage bucket `employee-images` (or use uploads under existing `blog-images/employees/` — see TeamEmployeesAdminPage).

# Minimal admin credentials for local admin panel (use strong credentials in prod)
VITE_ADMIN_USER=admin
VITE_ADMIN_PASS=changeme

# Legacy Supabase (not used while supabaseClient.js re-exports dbClient.js)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=public-anon-key
